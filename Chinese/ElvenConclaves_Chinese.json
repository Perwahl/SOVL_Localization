{
  "TranslationContext": "This file contains Unit Names for the Elven Conclaves Faction.",
  "Translations": [
    {
      "Key": "Elven Conclaves",
      "Translation": "精灵议会",
      "Comment": "代表精灵社会中有组织的、议会式的本质。"
    },
    {
      "Key": "Elf Spears",
      "Translation": "精灵矛手",
      "Comment": "持矛的精灵战士，是精灵步兵的标配。"
    },
    {
      "Key": "Elf City Guard",
      "Translation": "精灵城市守卫",
      "Comment": "守卫城市的精锐守卫队伍。"
    },
    {
      "Key": "Weapon Masters",
      "Translation": "武器大师",
      "Comment": "代表精锐技艺与掌握，精灵战士的精华。"
    },
    {
      "Key": "Elf Archers",
      "Translation": "精灵弓手",
      "Comment": "精灵以箭术著称，这正是他们的特色。"
    },
    {
      "Key": "Elf Watchers",
      "Translation": "精灵守望者",
      "Comment": "代表警觉与守护的精灵战士。"
    },
    {
      "Key": "Elf Bolt Thrower",
      "Translation": "精灵弩炮",
      "Comment": "远程攻城武器，精灵的重型火力。"
    },
    {
      "Key": "Elf Lancers",
      "Translation": "精灵枪骑兵",
      "Comment": "骑乘战马的精灵骑兵，优雅而致命。"
    },
    {
      "Key": "Elf Reavers",
      "Translation": "精灵掠夺者",
      "Comment": "迅速突击并撤退的快速骑兵。"
    },
    {
      "Key": "Elf Chariot",
      "Translation": "精灵战车",
      "Comment": "精灵的经典军事载具。"
    },
    {
      "Key": "Giant Eagle",
      "Translation": "巨鹰",
      "Comment": "宏伟的生物，适合精灵军队的座骑。"
    },
    {
      "Key": "Dragon Knights",
      "Translation": "龙骑士",
      "Comment": "骑乘龙兽的精锐战士，力量强大。"
    },
    {
      "Key": "Ancient Dragon",
      "Translation": "上古龙兽",
      "Comment": "强调古老的年纪与无比的力量。"
    },
    {
      "Key": "Gryphon",
      "Translation": "狮鹫",
      "Comment": "神话生物，代表精灵的尊贵。"
    },
    {
      "Key": "Elf Noble",
      "Translation": "精灵贵族",
      "Comment": "精灵社会中的贵族领导者。"
    },
    {
      "Key": "Elf Mage",
      "Translation": "精灵法师",
      "Comment": "掌握魔法的精灵术士。"
    },
    {
      "Key": "Elf Spellsword",
      "Translation": "精灵魔剑士",
      "Comment": "战斗与魔法完美结合的混合型战士。"
    }
  ]
}